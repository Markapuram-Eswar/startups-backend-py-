# HTTP server (uvicorn defaults if unset)
HOST=0.0.0.0
PORT=8000

# Database — same variables as Node backend (see backend/sample.env)
# Option A: single URL
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Option B: pieces
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSLMODE=require
DB_SSL_REJECT_UNAUTHORIZED=true

# Auth
JWT_SECRET=replace-with-long-random-string-at-least-32-chars
ADMIN_KEY=

# Frontend (CORS + email links)
FRONTEND_URL=http://localhost:5173

# SMTP (OTP / invites)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=IITTNiF

SHOW_OTP_IN_RESPONSE=false

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=
S3_BUCKET_REGION=ap-south-1
S3_PRESIGNED_GET_SECONDS=3600
# S3_PUBLIC_BASE_URL=
